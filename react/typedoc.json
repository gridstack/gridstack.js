{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "projects/lib/src/gridstack.tsx",
    "projects/lib/src/gridstack-item.tsx",
    "projects/lib/src/hooks.ts",
    "projects/lib/src/base-widget.tsx",
    "projects/lib/src/types.ts",
    "projects/lib/src/registry.ts",
    "projects/lib/src/gridstack-context.tsx",
    "projects/lib/src/gridstack-widget-context.tsx"
  ],
  "tsconfig": "tsconfig.doc.json",
  "excludeExternals": true,
  "externalPattern": ["**/dist/**", "node_modules/**"],
  "externalSymbolLinkMappings": {
    "gridstack": {
      "GridStackWidget": "../../../doc/API.md#gridstackwidget",
      "GridStackOptions": "../../../doc/API.md#gridstackoptions",
      "GridStackNode": "../../../doc/API.md#gridstacknode",
      "CoreGridStackWidget": "../../../doc/API.md#gridstackwidget",
      "CoreGridStackOptions": "../../../doc/API.md#gridstackoptions",
      "CoreGridStackNode": "../../../doc/API.md#gridstacknode",
      "GridHTMLElement": "../../../doc/API.md#gridhtmlelement",
      "GridItemHTMLElement": "../../../doc/API.md#griditemhtmlelement",
      "CoreGridHTMLElement": "../../../doc/API.md#gridhtmlelement",
      "CoreGridItemHTMLElement": "../../../doc/API.md#griditemhtmlelement"
    }
  },
  "out": "doc/api",
  "plugin": ["typedoc-plugin-markdown"],
  "theme": "markdown",
  "exclude": [
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.test.ts",
    "**/*.test.tsx",
    "node_modules/**"
  ],
  "excludePrivate": true,
  "excludeProtected": false,
  "excludeInternal": true,
  "includeVersion": true,
  "sort": ["source-order"],
  "sortEntryPoints": false,
  "kindSortOrder": [
    "Class",
    "Interface",
    "TypeAlias",
    "Variable",
    "Function"
  ],
  "groupOrder": [
    "Components",
    "Classes",
    "Interfaces",
    "Type aliases",
    "Variables",
    "Functions"
  ],
  "categorizeByGroup": true,
  "defaultCategory": "Other",
  "categoryOrder": [
    "Main",
    "Components",
    "React Integration",
    "Types",
    "Hooks",
    "Utilities",
    "*"
  ],
  "readme": "none",
  "hidePageHeader": true,
  "hideBreadcrumbs": true,
  "hidePageTitle": false,
  "disableSources": false,
  "useCodeBlocks": true,
  "indexFormat": "table",
  "parametersFormat": "table",
  "interfacePropertiesFormat": "table",
  "classPropertiesFormat": "table",
  "enumMembersFormat": "table",
  "typeDeclarationFormat": "table",
  "propertyMembersFormat": "table",
  "expandObjects": false,
  "expandParameters": false,
  "blockTagsPreserveOrder": [
    "@param",
    "@returns",
    "@throws"
  ],
  "outputFileStrategy": "modules",
  "mergeReadme": false,
  "entryFileName": "index",
  "cleanOutputDir": true,
  "excludeReferences": true,
  "gitRevision": "master",
  "gitRemote": "origin",
  "name": "GridStack React Library"
}
