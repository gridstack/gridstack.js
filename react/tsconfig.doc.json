{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "declaration": true,
    "emitDeclarationOnly": true,
    "skipLibCheck": true,
    "strict": true,
    "paths": {
      "gridstack": ["../dist/gridstack"]
    }
  },
  "include": [
    "projects/lib/src/**/*.ts",
    "projects/lib/src/**/*.tsx"
  ],
  "exclude": [
    "projects/lib/gridstack-react.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.test.ts",
    "**/*.test.tsx",
    "node_modules/**"
  ]
}
