{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "emitDeclarationOnly": true,
    "skipLibCheck": true,
    "strict": false,
    "paths": {
      "gridstack": ["../dist/gridstack"]
    }
  },
  "include": [
    "projects/lib/src/**/*.ts"
  ],
  "exclude": [
    "projects/lib/gridstack-vue.test.ts",
    "**/*.spec.ts",
    "**/*.test.ts",
    "node_modules/**"
  ]
}
